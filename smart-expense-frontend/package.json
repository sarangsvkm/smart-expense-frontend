{
  "name": "smart-expense-manager-frontend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "mobile",
    "desktop",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @smart-expense/web",
    "dev:shared": "npm run watch -w @smart-expense/shared",
    "dev:all": "npm run dev:shared & npm run dev:web",
    "build:shared": "npm run build -w @smart-expense/shared",
    "build:web": "npm run build:shared && npm run build -w @smart-expense/web"
  }
}
