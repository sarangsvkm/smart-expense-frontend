# ─────────────────────────────────────────────────────────────────────────────
# SmartExpense Web — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ / VITE_ prefix makes variables available in the browser bundle.
# Never put secrets (DB passwords, private keys) in this file.
#
# Copy this file to .env.local for local overrides (git-ignored).
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (must NOT have a trailing slash)
# Local development: Vite proxy rewrites /api → http://localhost:8080/api
# so the value here is a relative path that works with the proxy.
VITE_API_URL=/api

# App metadata
VITE_APP_NAME=SmartExpense Manager
VITE_APP_VERSION=1.0.0
